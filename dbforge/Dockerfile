FROM php:8.2-apache

# Enable Apache mod_rewrite
RUN a2enmod rewrite

# Install MySQL PDO extension
RUN docker-php-ext-install pdo pdo_mysql

# Set Apache document root to /var/www/html/dbforge
ENV APACHE_DOCUMENT_ROOT /var/www/html

# Allow .htaccess overrides
RUN sed -i 's/AllowOverride None/AllowOverride All/g' /etc/apache2/apache2.conf

# Copy DBForge into the container
COPY dbforge/ /var/www/html/dbforge/

# Ensure logs directory is writable
RUN mkdir -p /var/www/html/dbforge/logs/er \
    && chown -R www-data:www-data /var/www/html/dbforge/logs \
    && chown www-data:www-data /var/www/html/dbforge/config.template.php \
    && chmod -R 755 /var/www/html/dbforge

# config.php needs to be writable by the installer
RUN touch /var/www/html/dbforge/config.php \
    && chown www-data:www-data /var/www/html/dbforge/config.php \
    && chmod 644 /var/www/html/dbforge/config.php

EXPOSE 80
